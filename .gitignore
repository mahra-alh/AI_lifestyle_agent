# DEPENDENCIES
# Node dependencies installed locally (huge, machine-specific)
node_modules/

# BUILD OUTPUT
# Compiled frontend files (generated automatically)
build/

# TESTING OUTPUT
# Code coverage reports
coverage/

# OS / SYSTEM FILES
# MacOS hidden system file
.DS_Store

# ENVIRONMENT VARIABLES
# Main env files (contain secrets or local config)
.env

# Any environment-specific files (development, production, etc.)
*.env

# LOG FILES
# Debug logs generated by npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# FIREBASE (LOCAL CACHE)
# Firebase CLI cache (not needed in repo)
.firebase/

# SECRET FILES
# Service account keys (Firebase, GCP, etc.)
serviceAccountKey.json

# Any JSON files containing secrets or keys
*secret*.json
*key*.json

# MACHINE LEARNING FILES
# Trained model files (can be large, avoid committing unless needed)
*.pkl      # scikit-learn / pickle models
*.h5       # Keras / TensorFlow models
*.pt       # PyTorch models
*.onnx     # ONNX modelsbackend/config/serviceAccountKey.json
serviceAccountKey.json
firebase-adminsdk*.json
backend/data/
*.bin
*.npy
*.pkl
*.csv
